# =========================================================================
# CloudWeb — Variables de entorno
#
# Copia este archivo a .env.local y rellena los valores reales.
# NUNCA hagas commit de .env.local. Está en .gitignore.
#
# En Vercel: configura todas estas en el dashboard, en los 3 entornos
# (Development, Preview, Production). Las marcadas como NEXT_PUBLIC_*
# son visibles en el navegador del usuario — no pongas secretos ahí.
# =========================================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# En producción: https://cloudweb.app

# Dominio raíz para sitios publicados (sin protocolo, sin trailing slash).
# Sirve para construir URLs como cafe-lua.{NEXT_PUBLIC_PUBLISH_DOMAIN}
NEXT_PUBLIC_PUBLISH_DOMAIN=localhost:3000
# En producción: cloudweb.app

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role: SOLO en servidor. NUNCA en código que llegue al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# --- Google OAuth (para Supabase Auth) ---
# Crear en: console.cloud.google.com → APIs & Services → Credentials
# Tipo: Web application
# Redirect URI local:  http://localhost:54321/auth/v1/callback
# Redirect URI prod:   https://<tu-ref>.supabase.co/auth/v1/callback
# En producción: configurar TAMBIÉN en el dashboard de Supabase → Auth → Providers → Google
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Anthropic (agente IA) ---
ANTHROPIC_API_KEY=
# Modelo del runner. Default Sonnet 4.6 (decisión MVP).
# Para subir a Opus en producción sin redeployar, cambia este env en Vercel.
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Price ID del único plan del MVP ($29/mes, trial 14 días)
NEXT_PUBLIC_STRIPE_PRICE_ID=

# --- MercadoPago (pagos Argentina, ARS) ---
# Access token de la aplicación de MP (producción, no sandbox).
# Se obtiene en: mercadopago.com.ar/developers → Tus aplicaciones → Credenciales
MERCADOPAGO_ACCESS_TOKEN=
# Plan ID si usas planes predefinidos en MP (opcional: createPreapproval
# también funciona sin plan, creando el monto al vuelo).
NEXT_PUBLIC_MP_PLAN_ID=

# --- Geo / País ---
# En local no hay headers de CDN (x-vercel-ip-country). Usa esto para
# simular un país en desarrollo. Ej: AR para Argentina, US para USA.
DEV_COUNTRY_OVERRIDE=

# --- Resend (email transaccional) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=hola@cloudweb.app
# Email del founder al que se notifican los soft-blocks de cuota
# (decisión: caso por caso para los primeros 50 usuarios).
FOUNDER_NOTIFY_EMAIL=

# --- Upstash Redis (rate limit) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- Sentry (errores) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# --- Posthog (analytics + replays) ---
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
