{
  "name": "nuweb",
  "version": "0.1.0",
  "private": true,
  "description": "Crea tu web hablando con un agente de IA. Publicada en un clic.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
