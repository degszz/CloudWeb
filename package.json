    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@react-email/components": "^0.0.28",
    "@sentry/nextjs": "^8.40.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.105.1",
    "@types/three": "^0.184.0",
    "@upstash/ratelimit": "^2.0.5",
